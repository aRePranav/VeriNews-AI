# Comma-separated list of allowed frontend origins for CORS.
# Set this to your real Vercel domain in production, e.g.:
# VERINEWS_ALLOWED_ORIGINS=https://verinews-ai.vercel.app
VERINEWS_ALLOWED_ORIGINS=*

# Optional override for the SQLite database file location.
# VERINEWS_DB_PATH=/app/data/verinews.db
